{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"declarationDir": "./lib/types",
		"rootDir": "./src",
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"strictNullChecks": false,
		"target": "es2022",
		"lib": ["es2020", "es5"],
		"noUnusedParameters": false,
		// "moduleResolution": "node16",
		"importHelpers": true,
		"noEmitOnError": true,
		"types": ["node"]
	},
	"include": ["src/**/*", "index.d.ts"]
}
